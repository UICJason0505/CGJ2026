  dialogueType: 0
  dialogueNodes:
  - nodeId: 0
    text: "\u7238\u7238\uFF0C\u4F60\u77E5\u9053\u4E3A\u4EC0\u4E48\u662F\u4E00\u6735\u82B1\uFF0C\u4E09\u6761\u9C7C\uFF0C\u4E03\u6735\u4E91\u5417\uFF1F"
    speakerName: son
    choices: []
    nextNodeId: 1
  - nodeId: 1
    text: "\u56E0\u4E3A\u8FD9\u662F\u5C0F\u7FBD\u7684\u751F\u65E5\uFF1F"
    speakerName: 
    choices: []
    nextNodeId: 2
  - nodeId: 2
    text: "\u7238\u7238\u4F60\u5FD8\u4E86\u5417\uFF1F\u662F\u56E0\u4E3A\u7238\u7238\u7684\u751F\u65E5\u57287\u670813\u65E5\u554A"
    speakerName: son
    choices: []
    nextNodeId: 3
  - nodeId: 3
    text: "\u5728\u6211\u5FC3\u91CC\uFF0C\u4F60\u548C\u5988\u5988\u6C38\u8FDC\u662F\u6211\u4E16\u754C\u91CC\u6700\u91CD\u8981\u7684\u4EBA"
    speakerName: son
    choices: []
    nextNodeId: -1
  - nodeId: 3
    text: "\u5728\u6211\u5FC3\u91CC\uFF0C\u4F60\u548C\u5988\u5988\u6C38\u8FDC\u662F\u6211\u4E16\u754C\u91CC\u6700\u91CD\u8981\u7684\u4EBA"
    speakerName: son
    choices: []
    nextNodeId: 4
  - nodeId: 4
    text: "\uFF08\u533B\u9662\u91CC\uFF0C\u4E00\u4E2A\u9752\u5E74\u7537\u5B50\u966A\u5728\u4F60\u8EAB\u65C1\uFF0C\u8FD9\u4E00\u6B21\uFF0C\u4F60\u7EC8\u4E8E\u770B\u6E05\u4E86\u4ED6\u7684\u8138\uFF09"
    speakerName: SON
    choices: []
    nextNodeId: 5
  - nodeId: 5
    text: "\u4F60\u662F\u8C01\uFF1F"
    speakerName: 
    choices: []
    nextNodeId: 6
  - nodeId: 6
    text: "\u6211\u662F\u6765\u7167\u987E\u60A8\u7684"
    speakerName: SON
    choices: []
    nextNodeId: 7
  - nodeId: 7
    text: "\u4F60\u662F\u5C0F\u7FBD\u627E\u6765\u7684\u2026\u2026\u62A4\u5DE5\uFF1F"
    speakerName: 
    choices: []
    nextNodeId: 8
  - nodeId: 8
    text: "\uFF08\u4ED6\u624B\u91CC\u7684\u5200\u505C\u4E86\u4E00\u4E0B\uFF0C\u7136\u540E\u4ED6\u7EE7\u7EED\u524A\u90A3\u53EA\u82F9\u679C\uFF0C\u4ED6\u628A\u82F9\u679C\u5207\u6210\u5C0F\u5757\uFF0C\u653E\u5728\u4E00\u4E2A\u767D\u8272\u7684\u74F7\u7897\u91CC\u3002\uFF09"
    speakerName: SON
    choices: []
    nextNodeId: 9
  - nodeId: 9
    text: "\u5BF9"
    speakerName: SON
    choices: []
    nextNodeId: 10
  - nodeId: 10
    text: "\u62A4\u5DE5\u3002"
    speakerName: SON
    choices: []
    nextNodeId: 11
  - nodeId: 11
    text: "\uFF08\u62FF\u51FA\u90A3\u5F20\u5BB6\u5EAD\u7167\u7247\uFF09\u4F60\u77E5\u9053\u5417"
    speakerName: 
    choices: []
    nextNodeId: 12
  - nodeId: 12
    text: "\u4ED6\u66FE\u7ECF\u8BF4\u4ED6\u957F\u5927\u540E\u8981\u6210\u4E3A\u4E16\u754C\u4E0A\u6700\u4F1F\u5927\u7684\u753B\u5BB6\uFF0C\u4F46\u8FD8\u6CA1\u7B49\u5230\u4ED6\u957F\u5927\uFF0C\u4ED6\u5C31\u6D88\u5931\u5728\u4E86\u6211\u7684\u4E16\u754C\uFF0C\u4ED6\u662F\u6211\u5728\u8FD9\u4E2A\u4E16\u754C\u6700\u6302\u5FF5\u7684\u4EBA"
    speakerName: 
    choices: []
