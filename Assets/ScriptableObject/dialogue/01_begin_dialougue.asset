  outcomeType: 0
  description: "\u5F00\u59CB\u7684\u5BF9\u8BDD"
  dialogueType: 1
  dialogueNodes:
  - nodeId: 0
    text: "\u70DB\u5149\u6643\u52A8\uFF0C\u5FAE\u5F31\u7684\u5149\u662F\u8FD9\u95F4\u5C4B\u5B50\u6700\u540E\u7684\u5149\u6E90\u3002\u4F60\u6C89\u6D6E\u4E8E\u8FD9\u9ED1\u6697\u6F6E\u6C34\uFF0C\u611F\u53D7\u7740\u8FD9\u51B0\u51B7\u7684\u65E0\u4EBA\u7684\u5E73\u9759\uFF0C\u4EFB\u7531\u6F6E\u6C34\u62BD\u79BB\u8D70\u8EAB\u4F53\u7684\u6E29\u5EA6\u3002\n"
    speakerName: 
    choices: []
    nextNodeId: 1
  - nodeId: 1
    text: "\u4F60\u5DF2\u7ECF\u5F88\u7D2F\u4E86\uFF0C\u7A81\u7136\u89C9\u5F97\u62E5\u62B1\u8FD9\u67D4\u8F6F\u7684\u5E73\u9759\u4E5F\u672A\u5C1D\u4E0D\u662F\u4E00\u79CD\u9009\u62E9\u3002"
    speakerName: 
    choices:
    - choiceText: "\u6C89\u5165\u51B0\u51B7\u67D4\u8F6F\u7684\u6C89\u5BC2"
      responseText: "\u6C89\u5165\u51B0\u51B7\u67D4\u8F6F\u7684\u6C89\u5BC2"
      nextNodeId: 2
    - choiceText: "\u6211\u8FD8\u2026\u2026\u4E0D\u80FD\u2026\u2026"
      responseText: "\u6211\u8FD8\u2026\u2026\u4E0D\u80FD\u2026\u2026"
      nextNodeId: 3
    nextNodeId: -1
  - nodeId: 2
    text: "\u547C\uFF0C\u9ED1\u6697\u8F7B\u629A\u7740\u4F60\u7684\u8EAB\u4F53\uFF0C\u4EFF\u4F5B\u6BCF\u4E00\u5BF8\u795E\u7ECF\u90FD\u5728\u6EB6\u89E3\uFF0C\u4F60\u611F\u5230\u4E45\u8FDD\u7684\u8F7B\u677E"
    speakerName: 
    choices:
    - choiceText: "\u95ED\u4E0A\u53CC\u773C\uFF0C\u4FDD\u6301\u8FD9\u79CD\u72B6\u6001"
      responseText: "\u95ED\u4E0A\u53CC\u773C\uFF0C\u4FDD\u6301\u8FD9\u79CD\u72B6\u6001"
      nextNodeId: 4
    nextNodeId: -1
  - nodeId: 3
    text: "\u4F46\u4F60\u592A\u7D2F\u4E86\uFF0C\u7D27\u7EF7\u7684\u795E\u7ECF\u4EE4\u4F60\u7684\u8111\u888B\u53D1\u80C0\uFF0C\u4F60\u592A\u9700\u8981\u4F11\u606F\u4E00\u4E0B\u4E86"
    speakerName: 
    choices:
    - choiceText: "\u6C89\u5165\u51B0\u51B7\u67D4\u8F6F\u7684\u6C89\u5BC2"
      responseText: "\u6C89\u5165\u51B0\u51B7\u67D4\u8F6F\u7684\u6C89\u5BC2"
      nextNodeId: 2
    nextNodeId: -1
  - nodeId: 4
    text: "\u6307\u5C16\u7684\u89E6\u611F\u523A\u7834\u4E86\u6C89\u5BC2\uFF0C\u4F46\u4F60\u5374\u4E0D\u60F3\u7406\u4F1A"
    speakerName: 
    choices: []
    nextNodeId: 5
  - nodeId: 5
    text: "\u4EFB\u7531\u5B83\u4E00\u6B21\u6B21\u7684\u8B66\u544A\uFF0C\u76F4\u5230\u4F60\u518D\u4E5F\u65E0\u6CD5\u5FFD\u7565"
    speakerName: 
    choices:
    - choiceText: "\u7741\u5F00\u53CC\u773C"
      responseText: "\u2026\u2026"
      nextNodeId: 6
    nextNodeId: 5
  - nodeId: 6
    text: "\u90A3\u662F\u4E00\u4E2A\u6241\u5E73\u7684\u957F\u65B9\u4F53\uFF0C\u901A\u4F53\u5929\u7A7A\u84DD\uFF0C\u4E0A\u9762\u6709\u7740\u91D1\u8272\u7684\u7B26\u53F7\u3002\u4F60\u5C1D\u8BD5\u6253\u5F00\u5B83\uFF0C\u5F88\u8F7B\u677E\uFF0C\u4ED6\u5C31\u88AB\u4F60\u6253\u5F00\u4E86\n"
    speakerName: 
    choices:
    - choiceText: "\u6211\u559C\u6B22\u84DD\u8272"
      responseText: "\u6211\u559C\u6B22\u84DD\u8272"
      nextNodeId: 7
    - choiceText: "\u4E00\u672C\u2026\u2026\u300A\u5C24\u5229\u897F\u65AF\u300B"
      responseText: "\u4E00\u672C\u2026\u2026\u300A\u5C24\u5229\u897F\u65AF\u300B"
      nextNodeId: 8
    - choiceText: "\u2026\u2026"
      responseText: "\u2026\u2026"
      nextNodeId: 6
    nextNodeId: 5
  - nodeId: 7
    text: "\u5BF9\uFF0C\u84DD\u8272\uFF0C\u5929\u7A7A\u7684\u989C\u8272\u3002\u4F60\u559C\u6B22\u84DD\u8272\uFF0C\u5B83\u8C61\u5F81\u7740\u81EA\u7531"
    speakerName: 
    choices: []
    nextNodeId: 6
  - nodeId: 8
    text: "\u4E66\uFF0C\u4F60\u8BB0\u8D77\u4E86\u8FD9\u4E2A\u957F\u65B9\u4F53\u7684\u540D\u5B57\uFF0C\u4E5F\u8BA4\u51FA\u4E86\u91D1\u8272\u7684\u7B26\u53F7\u662F\u5B57"
    speakerName: 
    choices:
    - choiceText: "\u8FD9\u672C\u4E66\u8BB2\u4E86\u4EC0\u4E48"
      responseText: "\u8FD9\u672C\u4E66\u8BB2\u4E86\u4EC0\u4E48"
      nextNodeId: 9
    - choiceText: "\u5C1D\u8BD5\u9605\u8BFB"
      responseText: "\u5C1D\u8BD5\u9605\u8BFB"
      nextNodeId: 10
    nextNodeId: 6
  - nodeId: 9
    text: "\u54E6\uFF0C\u4E00\u4E2A\u53EF\u601C\u4EBA\uFF0C\u610F\u8BC6\u6DF7\u4E71\uFF0C\u5B64\u72EC\u8FF7\u60D8"
    speakerName: 
    choices: []
    nextNodeId: 8
  - nodeId: 10
    text: "\u4F60\u60F3\u4ED4\u7EC6\u770B\u6E05\u5176\u4E2D\u7684\u5185\u5BB9\uFF0C\u4F46\u4E66\u9875\u4E0A\u7684\u5B57\u7B26\u5982\u989C\u6599\u822C\u5316\u5F00\uFF0C\u626D\u66F2\uFF0C\u4E0D\u53EF\u8FA8\u8BC6\u3002"
    speakerName: 
    choices:
    - choiceText: "\u5C1D\u8BD5\u770B\u6E05"
      responseText: "\u5C1D\u8BD5\u770B\u6E05"
      nextNodeId: 11
    nextNodeId: 8
  - nodeId: 11
    text: "\u4F60\u52AA\u529B\u8FA8\u8BC6\u7740\u5176\u4E2D\u7684\u5185\u5BB9\uFF0C\u50CF\u662F\u6025\u4E8E\u4FA6\u7834\u654C\u519B\u60C5\u62A5\u7684\u4FA6\u63A2\u3002\u4F46\u4E66\u6CA1\u7ED9\u4F60\u65F6\u95F4\uFF0C\u4ED6\u5F00\u59CB\u6162\u6162\u878D\u5316\uFF0C\u6EB6\u89E3\u5230\u8FD9\u9ED1\u6697\u4E4B\u4E2D"
    speakerName: 
    choices:
    - choiceText: "\u4E0D\uFF0C\u4E0D\u884C\u2026\u2026"
      responseText: "\u4E0D\uFF0C\u4E0D\u884C\u2026\u2026"
      nextNodeId: 12
    nextNodeId: 8
  - nodeId: 12
    text: "\u4F60\u6253\u635E\u7740\u9010\u6E10\u6EB6\u89E3\u4E8E\u9ED1\u6697\u7684\u6CB9\u58A8\uFF0C\u7EDD\u671B\u7684\u60F3\u4ECE\u5176\u4E2D\u635E\u56DE\u4E9B\u4EC0\u4E48\u3002\u4F46\u65E0\u6D4E\u4E8E\u4E8B\uFF0C\u4E66\u672C\u6D41\u8FC7\u4F60\u7684\u6307\u5C16\uFF0C\u6700\u7EC8\u9690\u79D8\u4E8E\u9ED1\u6697\u3002"
