  - nodeId: 15
    text: "\u8FD9\u6211\u80AF\u5B9A\u8BB0\u5F97\uFF0C\u6211\u521A\u56DE\u5FC6\u8FC7\u7684\uFF0C\u4F60\u8FD9\u4E48\u5BF9\u81EA\u5DF1\u8BF4\u3002"
